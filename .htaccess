# cPanel / WAMP: project root (when document root is NOT the public/ folder)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block web access to application code (Apache 2.4 + 2.2)
    RewriteRule ^(app|config|core|database|routes|backups)(/|$) - [F,L]

    # Front controller lives in public/
    RewriteRule ^$ public/ [L]
    RewriteRule ^public/ - [L]
    RewriteRule (.*) public/$1 [L]
</IfModule>

Options -Indexes
